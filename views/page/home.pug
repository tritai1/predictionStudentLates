extends ../layout/home.pug

block content
  h1 Dự đoán xác suất đi trễ

  if error
    .alert.error #{error}

  form(method="POST" action="/")
    .form-grid
      input(type="text" name="student_name" placeholder="Tên hoặc mã số sinh viên (tuỳ chọn)")

      select(name="weekday" required)
        option(value="") -- Chọn ngày trong tuần --
        option(value="Monday") Monday
        option(value="Tuesday") Tuesday
        option(value="Wednesday") Wednesday
        option(value="Thursday") Thursday
        option(value="Friday") Friday
        option(value="Saturday") Saturday
        option(value="Sunday") Sunday

      input(type="number" step="0.1" name="distance_km" placeholder="Khoảng cách (km)" required)

      select(name="weather" required)
        option(value="") -- Thời tiết --
        option(value="sunny") Sunny
        option(value="rainy") Rainy
        option(value="cloudy") Cloudy
        option(value="windy") Windy

      select(name="transport_mode" required)
        option(value="") -- Phương tiện --
        option(value="walk") Walk
        option(value="bike") Bike
        option(value="bus") Bus
        option(value="car") Car
        option(value="train") Train

      input(type="number" step="0.1" name="avg_speed_kmh" placeholder="Tốc độ TB (km/h)" required)
      input(type="number" step="0.1" name="sleep_hours" placeholder="Số giờ ngủ" required)

      select(name="alarm_used" required)
        option(value="") -- Báo thức --
        option(value="yes") Có
        option(value="no") Không

      input(type="number" min="7" max="17" name="hour_start_time" placeholder="Giờ học bắt đầu" required)

      select(name="class_importance" required)
        option(value="") -- Tầm quan trọng lớp học --
        option(value="low") Thấp
        option(value="medium") Trung bình
        option(value="high") Cao

      select(name="unexpected_event" required)
        option(value="") -- Sự kiện bất ngờ --
        option(value="yes") Có
        option(value="no") Không

      select(name="traffic_condition" required)
        option(value="") -- Tình trạng giao thông --
        option(value="light") Thông thoáng
        option(value="moderate") Vừa phải
        option(value="heavy") Đông đúc

      input(type="number" step="0.01" min="0.1" max="1.0" name="habitual_punctuality" placeholder="Thói quen đúng giờ (0.1-1.0)" required)

      input(type="number" step="0.1" name="preparation_time" placeholder="Thời gian chuẩn bị (phút)" required)

    button.submit(type="submit") DỰ ĐOÁN NGAY