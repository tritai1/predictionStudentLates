extends ../layout/home.pug

block content
  .result-hero(class=level)
    .result-heading
      span.badge Kết quả dự đoán
      h2 Xin chào #{name}!
      if probability >= 70
        p.status-label.alert Cảnh báo: Xác suất đi trễ rất cao! Cần thay đổi lịch trình ngay.
      else if probability >= 40
        p.status-label.warning Có nguy cơ đi trễ, hãy chuẩn bị kỹ hơn và theo dõi điều kiện thực tế.
      else
        p.status-label.safe Bạn rất đúng giờ, tiếp tục duy trì thói quen hiện tại!

      p.model-used
        | Mô hình đang dùng:
        span.name-label #{selectedModel || 'RandomForestClassifier'}

    .probability-card
      span.caption Mức nguy cơ
      .probability-value
        span.number #{probability}%
        span.context dựa trên mô hình đã chọn
      .bar
        .fill(style=`width: ${probability}%`)

  if probabilities
    section.model-comparison
      h3 So sánh giữa các mô hình
      p.note Xem thử các mô hình khác dự đoán như thế nào để chọn phương án phù hợp.
      .model-grid
        each prob, modelName in probabilities
          - const delta = (prob - probability).toFixed(1)
          .model-card(class=modelName === selectedModel ? 'active' : '')
            span.model-name #{modelName}
            span.model-percent #{prob}%
            if modelName === selectedModel
              span.model-tag Đang sử dụng
            else
              span.model-delta #{delta > 0 ? '+' : ''}#{delta}%

  .result-details
    .detail-card
      h3 Gợi ý hành động
      ul
        if probability >= 70
          li Xuất phát sớm hơn ít nhất 20 phút và chọn tuyến đường ít tắc.
          li Kiểm tra lại phương tiện hoặc chọn phương án dự phòng.
          li Sử dụng báo thức kép và yêu cầu bạn bè nhắc nhở.
        else if probability >= 40
          li Chuẩn bị đồ dùng trước khi đi ngủ để tránh quên.
          li Theo dõi điều kiện thời tiết trước 12h.
          li Giữ tốc độ ổn định, tránh dừng đỗ không cần thiết.
        else
          li Tiếp tục duy trì thói quen tốt và ngủ đủ giấc.
          li Nếu lịch học thay đổi, hãy cập nhật lại hệ thống.
          li Chia sẻ kinh nghiệm đúng giờ với bạn bè.

    .detail-card
      h3 Thông tin nhanh
      .info-row
        span.label Nhóm rủi ro
        span.value= level === 'high' ? 'Cao' : level === 'medium' ? 'Trung bình' : 'Thấp'
      .info-row
        span.label Mốc an toàn khuyến nghị
        span.value #{probability >= 40 ? 'Trước 15 phút' : 'Trước 10 phút'}
      .info-row
        span.label Xác suất đúng giờ
        span.value #{(100 - probability).toFixed(1)}%

    .detail-card.inputs-card
      h3 Dữ liệu đã nhập
      if inputs
        -
          const fieldOrder = [
            { key: 'weekday', label: 'Ngày học' },
            { key: 'distance_km', label: 'Khoảng cách (km)' },
            { key: 'weather', label: 'Thời tiết' },
            { key: 'transport_mode', label: 'Phương tiện' },
            { key: 'avg_speed_kmh', label: 'Tốc độ TB (km/h)' },
            { key: 'sleep_hours', label: 'Giờ ngủ' },
            { key: 'alarm_used', label: 'Báo thức' },
            { key: 'hour_start_time', label: 'Giờ học' },
            { key: 'class_importance', label: 'Tầm quan trọng' },
            { key: 'unexpected_event', label: 'Sự kiện bất ngờ' },
            { key: 'traffic_condition', label: 'Giao thông' },
            { key: 'habitual_punctuality', label: 'Thói quen đúng giờ' },
            { key: 'preparation_time', label: 'Thời gian chuẩn bị (phút)' },
          ];
        .input-grid
          each field in fieldOrder
            - const value = inputs[field.key];
            if value !== undefined && value !== ''
              .input-pill
                span.label #{field.label}
                span.value #{value}
      else
        p.note Không có thông tin đầu vào để hiển thị.

  .result-actions
    a.back.primary(href="/") Dự đoán lại